# API runtime
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Security
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

# Database
DATABASE_URL=postgresql://backflow:backflow@localhost:5432/backflow_compliance?schema=public

# S3-compatible storage (MinIO local, S3 production)
S3_BUCKET=backflow-compliance
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/backflow-compliance
